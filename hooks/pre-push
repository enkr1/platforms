#!/bin/sh
# Guard: block pushing an UNOBFUSCATED / hand-edited hero homepage.
#
# index.html is BUILD OUTPUT of _platforms_unencrypted_js/hero-build.js. A correct
# build always contains obfuscator-renamed identifiers ("_0x"), and NEVER contains
# the raw-source module comment "Web-font gate" (comments are stripped by the
# obfuscator's compact mode — that string only exists in hero.src.html).
#
# Fix when blocked: from the _platforms/ root run
#     node _platforms_unencrypted_js/hero-build.js
# (or use the deploy_hero alias, which builds first).

HTML="index.html"

if [ -f "$HTML" ]; then
  if ! grep -q "_0x" "$HTML"; then
    echo "" >&2
    echo "  ⛔  PUSH BLOCKED: $HTML has no \"_0x\" obfuscation marker — not a hero-build output." >&2
    echo "      Rebuild first (from the _platforms/ root):" >&2
    echo "          node _platforms_unencrypted_js/hero-build.js" >&2
    echo "      or deploy via the alias (builds automatically):" >&2
    echo "          deploy_hero" >&2
    echo "" >&2
    exit 1
  fi
  if grep -q "Web-font gate" "$HTML"; then
    echo "" >&2
    echo "  ⛔  PUSH BLOCKED: $HTML contains raw-source marker \"Web-font gate\"." >&2
    echo "      GitHub Pages would serve your readable hero source code." >&2
    echo "      Rebuild first (from the _platforms/ root):" >&2
    echo "          node _platforms_unencrypted_js/hero-build.js" >&2
    echo "      or deploy via the alias (builds automatically):" >&2
    echo "          deploy_hero" >&2
    echo "" >&2
    exit 1
  fi
fi

exit 0
